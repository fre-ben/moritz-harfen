---
import { Image } from "astro:assets";
import { useTranslations, getLangFromUrl } from "../../i18n/utils";
import euImg from "../../images/leader/EU.jpg";
import eplrImg from "../../images/leader/EPLR.jpg";
import hessenImg from "../../images/leader/Hessen.png";
import leaderImg from "../../images/leader/LEADER.jpg";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  class="grid mt-20 gap-y-5 border-highlight border-t border-opacity-50 pt-20"
>
  <div class="grid sm:grid-cols-leader gap-x-5 items-center gap-y-5">
    <a
      target="_blank"
      rel="noreferrer"
      href="https://ec.europa.eu/info/food-farming-fisheries/key-policies/common-agricultural-policy/rural-development_de#ruraldevelopmentprogrammes"
      class="justify-self-start sm:justify-self-center lg:justify-self-end"
    >
      <Image src={euImg} alt="Logo EU" width={150} height={99} quality={100} />
    </a>
    <p class="justify-self-start" set:html={t("leaderDisclaimer.eu")} />
    <a
      target="_blank"
      rel="noreferrer"
      href="http://eler.hessen.de"
      class="justify-self-start sm:justify-self-center lg:justify-self-end"
    >
      <Image
        src={hessenImg}
        alt="Logo Hessen"
        width={100}
        height={126}
        quality={100}
      />
    </a>
    <p set:html={t("leaderDisclaimer.hessen")} />
  </div>
  <div
    class="grid grid-flow-col gap-x-5 items-center justify-start sm:justify-center"
  >
    <a
      target="_blank"
      rel="noreferrer"
      href="https://umwelt.hessen.de/landwirtschaft/laendlicher-raum/foerderung-der-laendlichen-entwicklung/regionalentwicklung"
      class="justify-self-start sm:justify-self-center lg:justify-self-end"
    >
      <Image
        src={leaderImg}
        alt="Logo Leader"
        width={70}
        height={70}
        quality={100}
      />
    </a>
    <a target="_blank" rel="noreferrer" href="http://eler.hessen.de">
      <Image
        src={eplrImg}
        alt="Logo EPLR"
        width={62}
        height={69}
        quality={100}
      />
    </a>
  </div>
</section>
