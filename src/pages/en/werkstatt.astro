---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Content from "../../components/Content.astro";
import { useTranslations } from "../../i18n/utils";
import werkstatt1 from "../../images/werkstatt/Werkstatt_1.jpg";
import aalbrecht from "../../images/werkstatt/Aalbrecht.jpg";
import werkstatt2Neu from "../../images/werkstatt/Werkstatt_2_neu.jpg";

const t = useTranslations("en");
---

<Layout
  title={t("werkstatt.meta.title")}
  description={t("werkstatt.meta.content")}
  lang="en"
  canonicalPath="/en/werkstatt"
>
  <Content flow="row" headline={t("werkstatt.headline")}>
    <section class="lg:pl-20 md:w-11/12 lg:w-9/12 grid grid-flow-row gap-y-5">
      <div
        class="grid grid-flow-row sm:grid-flow-col gap-y-3 sm:gap-y-0 sm:gap-x-5 items-center"
      >
        <Image
          src={werkstatt1}
          alt={t("werkstatt.image_alt_1")}
          width={400}
          quality={100}
        />
        <p>{t("werkstatt.text_1")}</p>
      </div>
      <div
        class="grid grid-flow-row sm:grid-flow-col gap-y-3 sm:gap-y-0 sm:gap-x-5 items-center"
      >
        <Image
          src={aalbrecht}
          alt={t("werkstatt.image_alt_2")}
          width={200}
          quality={100}
          class="order-1 sm:order-2"
        />
        <p class="order-2 sm:order-1">{t("werkstatt.text_2")}</p>
      </div>
      <div
        class="grid grid-flow-row sm:grid-flow-col gap-y-3 sm:gap-y-0 sm:gap-x-5 items-center"
      >
        <Image
          src={werkstatt2Neu}
          alt={t("werkstatt.image_alt_3")}
          width={400}
          quality={100}
        />
        <p>{t("werkstatt.text_3")}</p>
      </div>
    </section>
  </Content>
</Layout>
