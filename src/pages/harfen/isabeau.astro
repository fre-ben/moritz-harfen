---
import Layout from "../../layouts/Layout.astro";
import Content from "../../components/Content.astro";
import ImageSlider from "../../components/imageslider/ImageSlider.astro";
import { useTranslations } from "../../i18n/utils";
import isabeau1 from "../../images/harfen/isabeau/Export-0102.jpg";
import isabeau2 from "../../images/harfen/isabeau/Export-0105.jpg";
import isabeau3 from "../../images/harfen/isabeau/Export-0124.jpg";
import isabeau4 from "../../images/harfen/isabeau/Export-0184.jpg";

const t = useTranslations("de");
const images = [
  { src: isabeau1, alt: "" },
  { src: isabeau2, alt: "" },
  { src: isabeau3, alt: "" },
  { src: isabeau4, alt: "" },
];
---

<Layout
  title={t("isabeau.meta.title")}
  description={t("isabeau.meta.content")}
  lang="de"
  canonicalPath="/harfen/isabeau"
>
  <Content flow="col" className="lg:grid-flow-col">
    <div
      slot="headline"
      class="grid grid-flow-row gap-y-2 md:gap-y-0 md:grid-flow-col md:justify-start md:gap-x-3"
    >
      <span>isabeau</span>
      <span>{t("isabeau.headline")}</span>
    </div>
    <div class="lg:pl-20 sm:pl-0">
      <ImageSlider images={images} id="isabeau-slider" />
    </div>
    <div class="md:w-10/12 lg:w-10/12">
      <p class="mb-5 lg:w-9/12 text-lg" set:html={t("isabeau.text")} />
      <table class="text-lg">
        <tr>
          <td>{t("harfen.saiten")}</td>
          <td class="pl-3">29 (a&lsquo;&lsquo;&lsquo;-A)</td>
        </tr>
        <tr>
          <td>{t("harfen.höhe")}</td>
          <td class="pl-3">{t("harfen.circa")} 92cm</td>
        </tr>
        <tr>
          <td>{t("harfen.gewicht")}</td>
          <td class="pl-3">{t("harfen.circa")} 4,5 kg</td>
        </tr>
        <tr>
          <td>{t("harfen.preis")}</td>
          <td class="pl-3" set:html={t("isabeau.preis")} />
        </tr>
      </table>
    </div>
  </Content>
</Layout>
<script>
  import Splide from "@splidejs/splide";

  new Splide("#isabeau-slider", {
    arrows: true,
    pagination: true,
    lazyLoad: "nearby",
    autoplay: false,
    rewind: true,
  }).mount();
</script>
