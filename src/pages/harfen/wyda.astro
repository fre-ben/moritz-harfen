---
import Layout from "../../layouts/Layout.astro";
import Content from "../../components/Content.astro";
import ImageSlider from "../../components/imageslider/ImageSlider.astro";
import { useTranslations } from "../../i18n/utils";
import wyda1 from "../../images/harfen/wyda/wyda-1.jpg";
import wyda2 from "../../images/harfen/wyda/wyda-2.jpg";
import wyda3 from "../../images/harfen/wyda/wyda-3.jpg";
import wyda4 from "../../images/harfen/wyda/wyda-4.jpg";
import wyda5 from "../../images/harfen/wyda/wyda-5.jpg";

const t = useTranslations("de");
const images = [
  { src: wyda1, alt: "" },
  { src: wyda2, alt: "" },
  { src: wyda3, alt: "" },
  { src: wyda4, alt: "" },
  { src: wyda5, alt: "" },
];
---

<Layout
  title={t("wyda.meta.title")}
  description={t("wyda.meta.content")}
  lang="de"
  canonicalPath="/harfen/wyda"
>
  <Content flow="col" className="lg:grid-flow-col">
    <div
      slot="headline"
      class="grid grid-flow-row gap-y-2 md:gap-y-0 md:grid-flow-col md:justify-start md:gap-x-3"
    >
      <span>wyda</span>
      <span>{t("wyda.headline")}</span>
    </div>
    <div class="lg:pl-20 sm:pl-0">
      <ImageSlider images={images} id="wyda-slider" />
    </div>
    <div class="md:w-10/12 lg:w-10/12">
      <p class="mb-5 w-11/12 text-lg" set:html={t("wyda.text")} />
      <table class="text-lg">
        <tr>
          <td>{t("harfen.saiten")}</td>
          <td class="pl-3">34 (a&lsquo;&lsquo;&lsquo;-C)</td>
        </tr>
        <tr>
          <td>{t("harfen.höhe")}</td>
          <td class="pl-3">{t("harfen.circa")} 118cm</td>
        </tr>
        <tr>
          <td>{t("harfen.gewicht")}</td>
          <td class="pl-3">{t("harfen.circa")} 7 kg</td>
        </tr>
        <tr>
          <td>{t("harfen.preis")}</td>
          <td class="pl-3" set:html={t("wyda.preis")} />
        </tr>
      </table>
    </div>
  </Content>
</Layout>
<script>
  import Splide from "@splidejs/splide";

  new Splide("#wyda-slider", {
    arrows: true,
    pagination: true,
    lazyLoad: "nearby",
    autoplay: false,
    rewind: true,
  }).mount();
</script>
